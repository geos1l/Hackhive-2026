# ElevenLabs - Used for TTS (required)
ELEVENLABS_API_KEY=... 

# OpenRouter - Used for Router AI (required)
# Get your API key from: https://openrouter.ai/settings/keys
# This key is used to access Gemini for classification
GEMINI_API_KEY=...

# Whisper model for local speech-to-text (optional, defaults to base.en)
# Options: tiny.en, base.en, small.en, medium.en, large-v2, large-v3
# Larger models = better accuracy but slower and more memory
WHISPER_MODEL=base.en

# Supabase - For benchmark database (required)
SUPABASE_URL=https://klszeubsjtmbbyjcnpcd.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# LLM API Keys (for routing - add as needed based on your Supabase database)
# The api_key_env field in your Supabase database should match these variable names
OPENAI_API_KEY=...
ANTHROPIC_API_KEY=...
# Add more as needed: COHERE_API_KEY, etc.