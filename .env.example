# ElevenLabs - Used for TTS (required)
ELEVENLABS_API_KEY=... 

# OpenRouter - Used for Router AI (required)
# Get your API key from: https://openrouter.ai/settings/keys
# This key is used to access Gemini and other LLMs via OpenRouter
GEMINI_API_KEY=...

# Whisper model for local speech-to-text (optional, defaults to base.en)
# Options: tiny.en, base.en, small.en, medium.en, large-v2, large-v3
# Larger models = better accuracy but slower and more memory
WHISPER_MODEL=base.en

# Gemini - Used for Router AI (required)
# Got my API key from OpenRouter
GEMINI_API_KEY=...